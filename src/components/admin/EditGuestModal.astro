---
---
<div id="edit-panel" class="hidden fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4 overflow-y-auto">
  <div class="bg-zinc-800/80 backdrop-blur-md border border-zinc-700 p-6 shadow-2xl border-l-4 border-l-pink-500 w-full max-w-4xl max-h-[90vh] overflow-y-auto rounded-sm">
    <div class="flex justify-between items-center mb-4 border-b border-zinc-800 pb-2">
      <h2 class="text-xl font-display text-zinc-100 uppercase tracking-widest">Edit Record</h2>
      <button type="button" class="close-edit-btn text-zinc-500 hover:text-zinc-300 font-bold">X</button>
    </div>

    <div id="edit-error" class="hidden bg-red-950/50 border border-red-500 text-red-200 p-4 mb-4 uppercase tracking-widest font-bold text-sm"></div>

    <form id="edit-guest-form" class="flex flex-col gap-6">
      <input type="hidden" name="action" value="edit" />
      <input type="hidden" name="id" id="edit-id" />
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-1">
          <label class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1 block">First</label>
          <input type="text" name="firstName" id="edit-first" required class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2" />
        </div>
        <div class="md:col-span-1">
          <label class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1 block">Last</label>
          <input type="text" name="lastName" id="edit-last" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2" />
        </div>
        <div class="md:col-span-1">
          <label class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1 block">Email</label>
          <input type="email" name="email" id="edit-email" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2" />
        </div>
        <div class="md:col-span-1">
          <label class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1 block">Phone</label>
          <input type="text" name="phoneNumber" id="edit-phone" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2" />
        </div>
        <div class="md:col-span-1">
          <label class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1 block">Role</label>
          <select name="role" id="edit-role" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 text-sm">
            <option value="guest">Guest</option>
            <option value="party">Party</option>
            <option value="admin">Main Act</option>
          </select>
        </div>
        <div class="md:col-span-1">
          <label class="text-xs font-bold uppercase tracking-widest text-amber-500 mb-1 block">Party Size</label>
          <select name="allocatedPlusOnes" id="edit-allocation" class="w-full bg-zinc-900/60 rounded-sm border border-amber-700 text-amber-500 font-bold px-3 py-2 text-sm text-center">
            <option value="0">+0</option>
            <option value="1">+1</option>
            <option value="2">+2</option>
            <option value="3">+3</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 bg-zinc-900/60 rounded-sm/50 p-4 border border-zinc-800">
        <div class="md:col-span-2">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-1">Main RSVP</p>
          <select name="rsvpStatus" id="edit-rsvp" class="w-full bg-zinc-900 border border-zinc-700 px-3 py-2 text-sm">
            <option value="pending">Pending</option>
            <option value="attending">Yes</option>
            <option value="declined">No</option>
          </select>
        </div>
        <div class="md:col-span-1">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-1">Dietary Notes</p>
          <input type="text" name="dietaryNotes" id="edit-notes" class="w-full bg-zinc-900 border border-zinc-700 px-3 py-2" />
        </div>
        <div class="md:col-span-1">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-1">Song Request</p>
          <input type="text" name="songRequest" id="edit-song" class="w-full bg-zinc-900 border border-zinc-700 px-3 py-2" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="edit-p-block border border-zinc-800 p-4" data-index="1">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-2">+1 Name & RSVP</p>
          <input type="text" name="p1Name" id="edit-p1name" placeholder="Name" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mb-2 text-sm" />
          <select name="p1Attending" id="edit-p1attending" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-2 py-2 text-xs">
            <option value="pending">Pending</option>
            <option value="true">Yes</option>
            <option value="false">No</option>
          </select>
          <input type="email" name="p1Email" id="edit-p1email" placeholder="Email" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" />
          <input type="text" name="p1PhoneNumber" id="edit-p1phone" placeholder="Phone" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" />
        </div>
        
        <div class="edit-p-block border border-zinc-800 p-4" data-index="2">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-2">+2 Name & RSVP</p>
          <input type="text" name="p2Name" id="edit-p2name" placeholder="Name" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mb-2 text-sm" />
          <select name="p2Attending" id="edit-p2attending" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-2 py-2 text-xs">
            <option value="pending">Pending</option>
            <option value="true">Yes</option>
            <option value="false">No</option>
          </select>
          <input type="email" name="p2Email" id="edit-p2email" placeholder="Email" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" />
          <input type="text" name="p2PhoneNumber" id="edit-p2phone" placeholder="Phone" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" />
        </div>

        <div class="edit-p-block border border-zinc-800 p-4" data-index="3">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-2">+3 Name & RSVP</p>
          <input type="text" name="p3Name" id="edit-p3name" placeholder="Name" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mb-2 text-sm" />
          <select name="p3Attending" id="edit-p3attending" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-2 py-2 text-xs">
            <option value="pending">Pending</option>
            <option value="true">Yes</option>
            <option value="false">No</option>
          </select>
          <input type="email" name="p3Email" id="edit-p3email" placeholder="Email" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" />
          <input type="text" name="p3PhoneNumber" id="edit-p3phone" placeholder="Phone" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" />
        </div>
      </div>
      
      <div class="flex justify-end mt-2 gap-4 border-t border-zinc-800 pt-4">
        <button type="button" class="close-edit-btn bg-zinc-700 hover:bg-zinc-600 text-zinc-200 font-bold uppercase tracking-widest px-6 py-2 rounded-sm transition-colors">Cancel</button>
        <button type="submit" class="bg-zinc-200 hover:bg-white text-zinc-900 font-bold uppercase tracking-widest px-8 py-2 rounded-sm transition-colors">Save Record</button>
      </div>
    </form>
  </div>
</div>

<script>
  const editAllocSelect = document.getElementById('edit-allocation');
  const editPBlocks = document.querySelectorAll('.edit-p-block');

  editAllocSelect?.addEventListener('change', () => {
    const alloc = parseInt((editAllocSelect as HTMLSelectElement).value);
    editPBlocks.forEach(block => {
      const idx = parseInt(block.getAttribute('data-index') || '0');
      const inputs = block.querySelectorAll('input, select');
      if (idx > alloc) {
        block.classList.add('opacity-30', 'grayscale');
        inputs.forEach(i => (i as HTMLInputElement).disabled = true);
      } else {
        block.classList.remove('opacity-30', 'grayscale');
        inputs.forEach(i => (i as HTMLInputElement).disabled = false);
      }
    });
  });

  const editForm = document.getElementById('edit-guest-form');
  const editError = document.getElementById('edit-error');

  editForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (editError) editError.classList.add('hidden');
    
    const formData = new FormData(editForm as HTMLFormElement);
    const email = formData.get('email');
    const phone = formData.get('phoneNumber');
    
    if (!email && !phone) {
        if (editError) {
            editError.textContent = 'You must provide either an email or a phone number for the main guest.';
            editError.classList.remove('hidden');
        }
        return;
    }

    try {
      const res = await fetch('/api/admin/guests', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: formData
      });
      const data = await res.json();
      if (!res.ok) {
        if (editError) {
          editError.textContent = data.error || 'An error occurred';
          editError.classList.remove('hidden');
        }
      } else {
        window.location.reload();
      }
    } catch (err) {
      if (editError) {
        editError.textContent = 'Network error occurred. Please try again.';
        editError.classList.remove('hidden');
      }
    }
  });

  document.querySelectorAll('.close-edit-btn').forEach(btn => btn.addEventListener('click', () => {
    document.getElementById('edit-panel')?.classList.add('hidden');
  }));
</script>