---
---
<div id="add-panel" class="hidden fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4 overflow-y-auto">
  <div class="bg-zinc-800/80 backdrop-blur-md border border-zinc-700 p-6 shadow-2xl border-l-4 border-l-pink-500 w-full max-w-4xl max-h-[90vh] overflow-y-auto rounded-sm">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-display text-zinc-100 uppercase tracking-widest">New Guest Record</h2>
      <button type="button" class="close-add-btn text-zinc-500 hover:text-zinc-300 font-bold">X</button>
    </div>
    
    <div id="add-error" class="hidden bg-red-950/50 border border-red-500 text-red-200 p-4 mb-4 uppercase tracking-widest font-bold text-sm"></div>
    
    <form id="add-guest-form" class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
      <input type="hidden" name="action" value="add" />
      <div class="md:col-span-1">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">First Name</label>
        <input type="text" name="firstName" required class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 text-zinc-100 px-3 py-2" />
      </div>
      <div class="md:col-span-1">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">Last Name</label>
        <input type="text" name="lastName" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 text-zinc-100 px-3 py-2" />
      </div>
      <div class="md:col-span-1">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">Email</label>
        <input type="email" name="email" id="add-email" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 text-zinc-100 px-3 py-2" />
      </div>
      <div class="md:col-span-1">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">Phone</label>
        <input type="text" name="phoneNumber" id="add-phone" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 text-zinc-100 px-3 py-2" />
      </div>
      <div class="md:col-span-1">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">Role</label>
        <select name="role" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 text-zinc-100 px-3 py-2 text-sm">
          <option value="guest">Guest</option>
          <option value="party">Party</option>
          <option value="admin">Main Act</option>
        </select>
      </div>
      <div class="md:col-span-1">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">Party Size (+)</label>
        <select name="allocatedPlusOnes" id="add-allocation" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 text-zinc-100 px-3 py-2 text-sm text-center">
          <option value="0">+0</option>
          <option value="1">+1</option>
          <option value="2">+2</option>
          <option value="3">+3</option>
        </select>
      </div>

      <div class="md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4 border-t border-zinc-800 pt-4 mt-2">
        <div class="add-p-block border border-zinc-800 p-4 opacity-30 grayscale" data-index="1">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-2">+1 Name & Info</p>
          <input type="text" name="p1Name" placeholder="Name" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mb-2 text-sm" disabled />
          <input type="email" name="p1Email" placeholder="Email" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" disabled />
          <input type="text" name="p1PhoneNumber" placeholder="Phone" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" disabled />
        </div>
        
        <div class="add-p-block border border-zinc-800 p-4 opacity-30 grayscale" data-index="2">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-2">+2 Name & Info</p>
          <input type="text" name="p2Name" placeholder="Name" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mb-2 text-sm" disabled />
          <input type="email" name="p2Email" placeholder="Email" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" disabled />
          <input type="text" name="p2PhoneNumber" placeholder="Phone" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" disabled />
        </div>

        <div class="add-p-block border border-zinc-800 p-4 opacity-30 grayscale" data-index="3">
          <p class="text-xs font-bold uppercase tracking-widest text-pink-400 mb-2">+3 Name & Info</p>
          <input type="text" name="p3Name" placeholder="Name" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mb-2 text-sm" disabled />
          <input type="email" name="p3Email" placeholder="Email" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" disabled />
          <input type="text" name="p3PhoneNumber" placeholder="Phone" class="w-full bg-zinc-900/60 rounded-sm border border-zinc-700 px-3 py-2 mt-2 text-sm" disabled />
        </div>
      </div>

      <div class="md:col-span-3 flex justify-end mt-2">
        <button type="submit" class="bg-zinc-200 hover:bg-white text-zinc-900 font-bold uppercase px-8 py-2 rounded-sm">Create</button>
      </div>
    </form>
  </div>
</div>

<script>
  const addAllocSelect = document.getElementById('add-allocation');
  const addPBlocks = document.querySelectorAll('.add-p-block');

  addAllocSelect?.addEventListener('change', () => {
    const alloc = parseInt((addAllocSelect as HTMLSelectElement).value);
    addPBlocks.forEach(block => {
      const idx = parseInt(block.getAttribute('data-index') || '0');
      const inputs = block.querySelectorAll('input');
      if (idx > alloc) {
        block.classList.add('opacity-30', 'grayscale');
        inputs.forEach(i => i.disabled = true);
      } else {
        block.classList.remove('opacity-30', 'grayscale');
        inputs.forEach(i => i.disabled = false);
      }
    });
  });

  const addForm = document.getElementById('add-guest-form');
  const addError = document.getElementById('add-error');

  addForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (addError) addError.classList.add('hidden');
    
    const formData = new FormData(addForm as HTMLFormElement);
    const email = formData.get('email');
    const phone = formData.get('phoneNumber');
    
    if (!email && !phone) {
        if (addError) {
            addError.textContent = 'You must provide either an email or a phone number for the main guest.';
            addError.classList.remove('hidden');
        }
        return;
    }

    try {
      const res = await fetch('/api/admin/guests', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: formData
      });
      const data = await res.json();
      if (!res.ok) {
        if (addError) {
          addError.textContent = data.error || 'An error occurred';
          addError.classList.remove('hidden');
        }
      } else {
        window.location.reload();
      }
    } catch (err) {
      if (addError) {
        addError.textContent = 'Network error occurred. Please try again.';
        addError.classList.remove('hidden');
      }
    }
  });

  document.querySelectorAll('.close-add-btn').forEach(btn => btn.addEventListener('click', () => {
    document.getElementById('add-panel')?.classList.add('hidden');
  }));
</script>