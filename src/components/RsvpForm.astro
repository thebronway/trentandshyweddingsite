---
// This form POSTs directly to the backend route you set up at pages/api/rsvp.ts
---
<form action="/api/rsvp" method="POST" class="max-w-md w-full bg-zinc-900 border border-zinc-800 p-8 rounded-sm shadow-2xl">
  <h2 class="text-4xl mb-2 text-zinc-100">Claim Your Ticket</h2>
  <p class="text-zinc-400 text-sm mb-8">Enter your email address to unlock the guest list, view your RSVP status, or update your info.</p>
  
  <div class="mb-6">
    <label for="email" class="block text-xs font-bold uppercase tracking-widest text-amber-700 mb-2">Email Address</label>
    <input 
      type="email" 
      id="email" 
      name="email" 
      required 
      class="w-full bg-zinc-950 border border-zinc-700 text-zinc-100 px-4 py-3 focus:outline-none focus:border-amber-600 focus:ring-1 focus:ring-amber-600 transition-colors"
      placeholder="you@example.com"
    />
  </div>
  
  <button 
    type="submit" 
    class="w-full bg-amber-700 hover:bg-amber-600 text-zinc-950 font-bold text-lg uppercase tracking-widest py-4 transition-colors">
    Access Guest List
  </button>
</form>