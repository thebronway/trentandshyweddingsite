---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';

const openers = [
  { name: "Alyssa", role: "Vocals / Entourage", img: "/images/alyssa.webp" },
  { name: "Ben", role: "Bass / The Roadies", img: "/images/ben.webp" },
  { name: "Brian", role: "Sound Guy / Officiant", img: "/images/brian.webp" },
  { name: "Carney", role: "Lead Guitar / The Roadies", img: "/images/carney.webp" },
  { name: "Devan", role: "Rhythm Guitar / Entourage", img: "/images/devan.webp" },
  { name: "Evan", role: "Tour Manager / Entourage", img: "/images/evan.webp" },
  { name: "Jake", role: "Drums / The Roadies", img: "/images/jake.webp" },
  { name: "Jordan", role: "Keys / Entourage", img: "/images/jordan.webp" },
  { name: "Jordy", role: "Lights / Entourage", img: "/images/jordy.webp" },
  { name: "Matt", role: "Security / The Roadies", img: "/images/matt.webp" },
  { name: "Nick", role: "Pyro / The Roadies", img: "/images/nick.webp" },
].sort((a, b) => a.name.localeCompare(b.name));
---
<Layout title="The Openers">
  <Nav />
  <main class="max-w-6xl mx-auto p-6 w-full mt-8">
    <div class="text-center mb-16">
      <h1 class="text-6xl text-zinc-100 font-display mb-4 uppercase tracking-wider">The Openers</h1>
      <p class="text-amber-600 font-bold tracking-widest uppercase text-sm">The wedding party warming up the stage for the main act</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {openers.map(person => (
        <div class="group relative bg-zinc-900 border border-zinc-800 overflow-hidden hover:border-amber-600 transition-colors">
          <div class="aspect-square bg-zinc-950 relative">
            <img 
              src={person.img} 
              alt={person.name} 
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="hidden absolute inset-0 flex items-center justify-center opacity-20 group-hover:opacity-40 transition-opacity bg-zinc-950">
                <svg class="w-20 h-20 text-zinc-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-transparent"></div>
          </div>
          <div class="p-4 absolute bottom-0 w-full text-center">
            <h3 class="text-2xl font-display text-zinc-100 uppercase tracking-widest leading-none">{person.name}</h3>
            <p class="text-amber-500 text-[10px] font-bold uppercase tracking-widest mt-2">{person.role}</p>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>