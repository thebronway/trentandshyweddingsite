---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
---
<Layout title="Merch Table">
  <Nav />
  <main class="max-w-4xl mx-auto p-6 w-full mt-8 text-center">
    <h1 class="text-4xl md:text-6xl text-zinc-100 font-display mb-8 uppercase">Merch Table</h1>
    
    <div class="bg-zinc-900 border border-zinc-800 p-8 shadow-2xl mb-12 text-left max-w-2xl mx-auto">
      <h2 class="text-2xl text-zinc-100 font-display mb-4 uppercase tracking-widest border-b border-zinc-800 pb-2">Support the Band</h2>
      <p class="text-zinc-300 leading-relaxed mb-4">
        Your presence in the pit is the only gift we really need. But if you’d like to support the band, we have two ways to contribute below.
      </p>
      <p class="text-zinc-400 leading-relaxed text-sm">
        <strong>The Deck Fund:</strong> We are currently tearing down and rebuilding our backyard deck to host our own afterparties. You can throw cash in the tip jar via Venmo, or drop a check in the card box at the venue.<br/><br/>
        <strong>The Registry:</strong> If you prefer to buy us physical gear for the house, check out our Target registry.
      </p>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-6 justify-center">
      <a href="https://venmo.com/TrentGarzoni" target="_blank" class="bg-amber-700 hover:bg-amber-600 text-zinc-950 font-bold text-lg uppercase tracking-widest px-8 py-4 transition-colors">
        The Deck Fund (Venmo)
      </a>
      <a href="https://target.com" target="_blank" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-100 font-bold text-lg uppercase tracking-widest px-8 py-4 transition-colors">
        Target Registry
      </a>
    </div>
  </main>
</Layout>