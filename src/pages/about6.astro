---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';

const openers = [
  { name: "Alyssa", role: "Vocals", order: 1, img: "/images/alyssa.webp" },
  { name: "Ben", role: "Bass", order: 2, img: "/images/ben.webp" },
  { name: "Brian", role: "Sound Guy / Officiant", order: 3, img: "/images/brian.webp" },
  { name: "Carney", role: "Lead Guitar", order: 4, img: "/images/carney.webp" },
  { name: "Devan", role: "Rhythm Guitar", order: 5, img: "/images/devan.webp" },
  { name: "Evan", role: "Tour Manager", order: 6, img: "/images/evan.webp" },
  { name: "Jake", role: "Drums", order: 7, img: "/images/jake.webp" },
  { name: "Jordan", role: "Keys", order: 8, img: "/images/jordan.webp" },
  { name: "Jordy", role: "Lights", order: 9, img: "/images/jordy.webp" },
  { name: "Matt", role: "Security", order: 10, img: "/images/matt.webp" },
  { name: "Nick", role: "Pyro", order: 11, img: "/images/nick.webp" },
].sort((a, b) => a.order - b.order);
---
<Layout title="Meet the Band - Theme 5">
  <div class="bg-gradient-to-b from-red-950 from-30% to-zinc-950 min-h-screen pb-12">
    <Nav />
    <main class="max-w-4xl mx-auto p-6 w-full mt-8 text-center text-zinc-100">
      <h1 class="text-4xl md:text-6xl text-white font-display mb-4 uppercase tracking-wider">Meet The Band</h1>
      <p class="text-pink-300 font-bold tracking-widest uppercase text-sm mb-12">Trent & Shy • Est. 2022</p>

      <div class="w-full h-64 sm:h-96 mb-12 border border-zinc-700 relative overflow-hidden group shadow-2xl">
        <img 
          src="/images/about.webp" 
          alt="Trent and Shy" 
          class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" 
        />
        <div class="absolute inset-0 border-[12px] border-zinc-800/40 pointer-events-none"></div>
      </div>

      <div class="bg-zinc-800/60 backdrop-blur-md border border-zinc-700 p-8 shadow-2xl mb-12 text-left rounded-sm">
        <h2 class="text-3xl text-pink-400 font-display mb-4 uppercase">How It Started</h2>
        <p class="text-zinc-200 leading-relaxed mb-6">
          It was 2022, and the energy at the Baltimore Soundstage was electric. Somewhere in the middle of the Knocked Loose pit, Trent and Shy collided. They spent the rest of the set shouting lyrics at each other, and by the time the house lights came up, they knew they’d found their permanent stage-dive partner.
        </p>

        <p class="text-zinc-200 leading-relaxed mb-6">
          Fast forward to 2026: we’re heading back to the scene of the crime. We’re trading the mosh pit for the altar and getting married right where it all started.
        </p>

        <p class="text-zinc-200 leading-relaxed">
          This isn't your traditional wedding. Wear black, come thirsty, and get ready for a heavy night.
        </p>
      </div>

      <div class="text-center mb-12 mt-20">
        <h2 class="text-4xl md:text-5xl text-white font-display mb-4 uppercase tracking-wider border-b border-zinc-700 pb-4 inline-block">The Openers</h2>
        <p class="text-pink-300 font-bold tracking-widest uppercase text-sm mt-4">The wedding party warming up the stage for the main act</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {openers.map(person => (
          <div class="group relative bg-zinc-800/60 backdrop-blur-md border border-zinc-700 overflow-hidden hover:border-pink-400 transition-colors rounded-sm shadow-lg">
            <div class="aspect-square bg-zinc-900 relative">
              <img 
                src={person.img} 
                alt={person.name} 
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <div class="hidden absolute inset-0 flex items-center justify-center opacity-20 group-hover:opacity-40 transition-opacity bg-zinc-800/60">
                  <svg class="w-20 h-20 text-pink-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-zinc-800 via-zinc-800/20 to-transparent"></div>
            </div>
          
            <div class="p-4 absolute bottom-0 w-full text-center">
              <h3 class="text-2xl font-display text-white uppercase tracking-widest leading-none">{person.name}</h3>
              <p class="text-pink-300 text-[10px] font-bold uppercase tracking-widest mt-2">{person.role}</p>
            </div>
          </div>
        ))}
      </div>
    </main>
  </div>
</Layout>