---
import Layout from '../components/Layout.astro';

const error = Astro.url.searchParams.get('error');
---
<Layout title="Enter Password">
  <main class="min-h-screen flex flex-col items-center justify-center p-6 bg-zinc-950">
    <div class="max-w-md w-full bg-zinc-900 border border-zinc-800 p-8 shadow-2xl">
      <div class="text-center mb-8">
        <h1 class="text-6xl text-zinc-100 font-display tracking-widest text-amber-600 mb-2">T & S</h1>
        <p class="text-zinc-400 font-bold tracking-widest uppercase text-sm">Enter Access Code</p>
      </div>

      {error === 'invalid' && (
        <div class="bg-red-900/50 border border-red-500 text-red-200 px-4 py-2 mb-6 text-sm text-center font-bold uppercase tracking-wider">
          Invalid Password
        </div>
      )}

      <form action="/api/auth" method="POST" class="flex flex-col gap-4">
        <input 
          type="password" 
          name="password" 
          required 
          placeholder="PASSWORD"
          class="w-full bg-zinc-950 border border-zinc-700 text-zinc-100 px-4 py-4 text-center tracking-widest focus:outline-none focus:border-amber-600 transition-colors"
        />
        <button type="submit" class="w-full bg-amber-700 hover:bg-amber-600 text-zinc-950 font-bold text-lg uppercase tracking-widest py-4 transition-colors">
          Unlock
        </button>
      </form>
    </div>
  </main>
</Layout>