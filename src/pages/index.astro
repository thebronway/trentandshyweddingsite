---
import Layout from '../components/Layout.astro';

const error = Astro.url.searchParams.get('error');
const redirectTo = Astro.url.searchParams.get('redirectTo') || '/about';
---
<Layout title="Presale Access">
  <main class="min-h-screen flex items-center justify-center p-6">
    <div class="max-w-5xl w-full flex flex-col md:flex-row bg-zinc-800/60 backdrop-blur-md border border-zinc-700 shadow-2xl overflow-hidden rounded-sm">
      
      <div class="md:w-1/2 bg-zinc-900/60 relative min-h-[400px] flex items-end p-8 border-b md:border-b-0 md:border-r border-zinc-700">
         <img src="/images/presale.webp" alt="Trent and Shy" class="absolute inset-0 w-full h-full object-cover object-center opacity-80" />
         <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/60 to-transparent"></div>
         
         <div class="relative z-10 w-full mt-auto">
           <h2 class="text-4xl md:text-6xl text-white font-display tracking-widest uppercase mb-2">Trent & Shy</h2>
           <p class="text-pink-400 font-bold uppercase tracking-wider text-sm mb-4">The "Till Death" Tour • One Night Only</p>
           
           <div class="space-y-1 border-l-2 border-pink-400 pl-4">
             <p class="text-zinc-300 uppercase tracking-widest text-xs font-bold">Oct 10, 2026</p>
             <p class="text-zinc-400 uppercase tracking-widest text-xs">Baltimore, MD</p>
           </div>
         </div>
      </div>

      <div class="md:w-1/2 p-8 md:p-12 flex flex-col justify-center bg-zinc-900/60">
        <div class="mb-8">
          <h1 class="text-3xl md:text-4xl text-white font-display tracking-widest uppercase mb-2">Unlock Site Access</h1>
          <p class="text-zinc-400 font-bold tracking-widest uppercase text-xs">Enter your presale code to unlock the site</p>
        </div>

        {error === 'invalid' && (
          <div class="bg-red-950/50 border border-red-900 text-red-500 px-4 py-3 mb-6 text-xs font-bold uppercase tracking-widest text-center">
            Invalid Presale Code
          </div>
        )}

        <form action="/api/verify" method="POST" class="flex flex-col gap-4">
          <input type="hidden" name="redirectTo" value={redirectTo} />
          <input 
            type="text" 
            name="code"
            required 
            placeholder="PRESALE CODE"
            oninput="this.value = this.value.toLowerCase().replace(/ /g, '')"
            class="w-full bg-zinc-900 border border-zinc-700 text-zinc-100 px-4 py-4 text-center tracking-widest uppercase focus:outline-none focus:border-pink-400 focus:ring-1 focus:ring-pink-400 transition-colors rounded-sm"
          />
          <button type="submit" class="w-full bg-zinc-200 hover:bg-white text-zinc-900 font-bold text-lg uppercase tracking-widest py-4 transition-colors rounded-sm">
            Unlock Site
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>