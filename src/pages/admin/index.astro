---
import Layout from '../../components/Layout.astro';
import Nav from '../../components/Nav.astro';
import { db } from '../../db';
import { guests, settings } from '../../db/schema';

// Import our new split components
import Headcount from '../../components/admin/Headcount.astro';
import RsvpSettings from '../../components/admin/RsvpSettings.astro';
import EmailLists from '../../components/admin/EmailLists.astro';
import GuestTable from '../../components/admin/GuestTable.astro';
import AddGuestModal from '../../components/admin/AddGuestModal.astro';
import EditGuestModal from '../../components/admin/EditGuestModal.astro';

const allGuests = await db.select().from(guests);
const siteSettingsQuery = await db.select().from(settings).limit(1);
const siteSettings = siteSettingsQuery[0] || { 
  rsvpOpenDate: new Date(), rsvpCloseDate: new Date(), earlyMessage: '', lateMessage: '' 
};

const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');

// Headcounts
let totalYes = 0;
let totalNo = 0;
let totalPending = 0;

allGuests.forEach(g => {
  if (!g.hasRsvpd) {
    totalPending += 1 + g.allocatedPlusOnes;
  } else {
    g.isAttending ? totalYes++ : totalNo++;

    if (g.allocatedPlusOnes >= 1) {
      if (g.p1Attending === 'true') { totalYes++; }
      else if (g.p1Attending === 'false') { totalNo++; }
      else { totalPending++; }
    }
    if (g.allocatedPlusOnes >= 2) {
      if (g.p2Attending === 'true') { totalYes++; }
      else if (g.p2Attending === 'false') { totalNo++; }
      else { totalPending++; }
    }
    if (g.allocatedPlusOnes >= 3) {
      if (g.p3Attending === 'true') { totalYes++; }
      else if (g.p3Attending === 'false') { totalNo++; }
      else { totalPending++; }
    }
  }
});

// Email Lists for Gmail (Including Plus Ones + Deduplicated)
let arrYes: string[] = [];
let arrNo: string[] = [];
let arrPending: string[] = [];
let arrAll: string[] = [];

allGuests.forEach(g => {
  // Main Guest
  if (g.email) {
    arrAll.push(g.email);
    if (!g.hasRsvpd) arrPending.push(g.email);
    else if (g.isAttending) arrYes.push(g.email);
    else arrNo.push(g.email);
  }
  
  // Plus Ones
  if (g.allocatedPlusOnes >= 1 && g.p1Email) {
    arrAll.push(g.p1Email);
    if (g.p1Attending === 'pending') arrPending.push(g.p1Email);
    else if (g.p1Attending === 'true') arrYes.push(g.p1Email);
    else arrNo.push(g.p1Email);
  }
  if (g.allocatedPlusOnes >= 2 && g.p2Email) {
    arrAll.push(g.p2Email);
    if (g.p2Attending === 'pending') arrPending.push(g.p2Email);
    else if (g.p2Attending === 'true') arrYes.push(g.p2Email);
    else arrNo.push(g.p2Email);
  }
  if (g.allocatedPlusOnes >= 3 && g.p3Email) {
    arrAll.push(g.p3Email);
    if (g.p3Attending === 'pending') arrPending.push(g.p3Email);
    else if (g.p3Attending === 'true') arrYes.push(g.p3Email);
    else arrNo.push(g.p3Email);
  }
});

const emailsYes = [...new Set(arrYes)].join(', ');
const emailsNo = [...new Set(arrNo)].join(', ');
const emailsPending = [...new Set(arrPending)].join(', ');
const emailsAll = [...new Set(arrAll)].join(', ');
---

<Layout title="Mission Control">
  <Nav />
  <main class="max-w-7xl mx-auto p-6 w-full mt-8">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end border-b border-zinc-800 pb-4 mb-6 gap-4">
      <h1 class="text-5xl text-zinc-100 font-display uppercase tracking-widest">Mission Control</h1>
      <div class="flex gap-2">
        <a href="/admin/faqs" class="bg-zinc-800 hover:bg-zinc-700 text-zinc-100 font-bold px-6 py-2 uppercase tracking-wider transition-colors text-sm border border-zinc-700">Manage FAQs</a>
        <a href="/api/admin/export.csv" class="bg-amber-700 hover:bg-amber-600 text-zinc-950 font-bold px-6 py-2 uppercase tracking-wider transition-colors text-sm">Export CSV</a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <Headcount totalYes={totalYes} totalNo={totalNo} totalPending={totalPending} />
      <RsvpSettings siteSettings={siteSettings} success={success} />
    </div>

    <EmailLists emailsYes={emailsYes} emailsPending={emailsPending} emailsNo={emailsNo} emailsAll={emailsAll} />

    {error === 'duplicate' && (
      <div class="bg-red-950/50 border border-red-500 text-red-200 p-4 mb-6 uppercase tracking-widest font-bold text-sm">Error: That email/phone number is already on the list!</div>
    )}
    {error === 'nocsv' && (
      <div class="bg-red-950/50 border border-red-500 text-red-200 p-4 mb-6 uppercase tracking-widest font-bold text-sm">Error: No CSV file was uploaded.</div>
    )}
    {success === 'imported' && (
      <div class="bg-emerald-950/50 border border-emerald-500 text-emerald-200 p-4 mb-6 uppercase tracking-widest font-bold text-sm">Success: Guest list imported!</div>
    )}

    <div class="flex flex-col md:flex-row gap-4 mb-8 bg-zinc-900 border border-zinc-800 p-4 shadow-xl">
      <input type="text" id="search-bar" placeholder="SEARCH NAME OR EMAIL..." class="flex-1 bg-zinc-950 border border-zinc-700 text-zinc-100 px-4 py-2 focus:border-amber-600 uppercase text-sm tracking-wider" />
      <button id="toggle-add-btn" class="bg-emerald-700 hover:bg-emerald-600 text-zinc-100 font-bold uppercase tracking-widest px-6 py-2 transition-colors">+ Add Guest</button>
      <form action="/api/admin/import-guests" method="POST" enctype="multipart/form-data" class="flex gap-2 items-center border-l border-zinc-700 pl-4">
        <input type="file" name="csv" accept=".csv" required class="text-xs text-zinc-400 file:mr-4 file:py-2 file:px-4 file:border-0 file:text-xs file:font-bold file:uppercase file:bg-zinc-800 file:text-zinc-100 hover:file:bg-zinc-700 cursor-pointer"/>
        <button type="submit" class="bg-zinc-100 hover:bg-zinc-300 text-zinc-950 font-bold uppercase tracking-widest px-4 py-2 text-xs transition-colors">Import CSV</button>
      </form>
    </div>

    <AddGuestModal />
    <EditGuestModal />
    <GuestTable allGuests={allGuests} />

  </main>
</Layout>

<script is:inline>
;(() => {
  const searchInput = document.getElementById('search-bar');
  const rows = document.querySelectorAll('.guest-row');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const term = searchInput.value.toLowerCase();
      rows.forEach(row => {
        row.style.display = row.dataset.search.includes(term) ? '' : 'none';
      });
    });
  }

  const toggleAddBtn = document.getElementById('toggle-add-btn');
  const addPanel = document.getElementById('add-panel');
  const editPanel = document.getElementById('edit-panel');
  const addError = document.getElementById('add-error');

  if (toggleAddBtn && addPanel && editPanel) {
    toggleAddBtn.addEventListener('click', () => {
      addPanel.classList.remove('hidden');
      editPanel.classList.add('hidden');
      if (addError) addError.classList.add('hidden');
    });
  }
})();
</script>