---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';

const faqs = [
  {
    q: "Is there an age limit for this show?",
    a: "Strictly 21+. Leave the kids at home, book a sitter, and come ready to party."
  },
  {
    q: "What is the dress code?",
    a: "Show-ready casual. We're getting married at a rock club, so wear what makes you feel like a VIP. Black is highly encouraged. Please leave the formal gowns, tuxedos, and white dresses in the closet. Pit-safe footwear recommended."
  },
  {
    q: "Where do I park the tour bus?",
    a: "The Baltimore Soundstage does not have its own parking lot. However, there are several parking garages within a 2-block radius (like the Pier V Garage). We highly recommend taking an Uber/Lyft if you plan on visiting the open bar."
  },
  {
    q: "Will there be food or just beer?",
    a: "Yes, we are providing a full dinner during the afterparty, plus an open bar. Make sure you select your meal choice when you claim your ticket at the Box Office."
  },
  {
    q: "Can I take pictures during the ceremony?",
    a: "Our ceremony is an unplugged set. Please keep your phones in your pockets so our professional photographer can get the shots without screens in the air. Once the reception hits, take as many photos as you want."
  }
];
---
<Layout title="Tour FAQ">
  <Nav />
  <main class="max-w-3xl mx-auto p-6 w-full mt-8">
    <h1 class="text-6xl text-zinc-100 font-display mb-8 uppercase tracking-wider text-center">Tour FAQ</h1>
    
    <div class="space-y-6">
      {faqs.map(faq => (
        <div class="bg-zinc-900 border border-zinc-800 p-6 shadow-xl border-l-4 border-l-amber-700">
          <h3 class="text-xl font-display text-zinc-100 uppercase tracking-widest mb-3">{faq.q}</h3>
          <p class="text-zinc-400 leading-relaxed text-sm">{faq.a}</p>
        </div>
      ))}
    </div>
    
    <div class="mt-12 text-center p-6 border border-zinc-800 bg-zinc-950">
      <p class="text-zinc-500 uppercase tracking-widest text-xs font-bold mb-2">Still have questions?</p>
      <a href="mailto:booking@trentandshy.com" class="text-amber-600 hover:text-amber-500 tracking-wider">Contact Management</a>
    </div>
  </main>
</Layout>