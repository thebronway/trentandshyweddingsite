---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
import { db } from '../db';
import { faqs } from '../db/schema';
import { asc } from 'drizzle-orm';

const faqsList = await db.select().from(faqs).orderBy(asc(faqs.sortOrder));
---
<Layout title="Tour FAQ">
  <Nav />
  <main class="max-w-3xl mx-auto p-6 w-full mt-8">
    <h1 class="text-4xl md:text-6xl text-zinc-100 font-display mb-8 uppercase tracking-wider text-center">Tour FAQ</h1>
    
    <div class="space-y-6">
      {faqsList.map(faq => (
        <div class="bg-zinc-800/60 backdrop-blur-md border border-zinc-700 p-6 shadow-xl border-l-4 border-l-pink-400 rounded-sm">
          <h3 class="text-xl font-display text-white uppercase tracking-widest mb-3">{faq.question}</h3>
          <div class="text-zinc-400 leading-relaxed text-sm prose prose-invert max-w-none" set:html={faq.answer}></div>
        </div>
      ))}
      
      {faqsList.length === 0 && (
        <p class="text-zinc-500 text-center uppercase tracking-widest text-sm">FAQ is currently empty. Check back later!</p>
      )}
    </div>
    
    <div class="mt-12 text-center p-6 border border-zinc-700 bg-zinc-800/60 backdrop-blur-md rounded-sm">
      <p class="text-zinc-300 uppercase tracking-widest text-xs font-bold mb-2">Still have questions?</p>
      <a href="mailto:shrentshredding@gmail.com" class="text-pink-400 hover:text-pink-300 tracking-wider font-bold">Email Trent and Shy</a>
    </div>
  </main>
</Layout>