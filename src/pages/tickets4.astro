---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
---
<Layout title="Box Office - Theme 3">
  <div class="bg-gradient-to-b from-red-900 to-zinc-900 min-h-screen pb-12">
    <Nav />
    <main class="max-w-3xl mx-auto p-6 w-full mt-8">
      
      <div class="bg-zinc-900/60 backdrop-blur-md border border-pink-800 p-6 mb-8 border-l-4 border-l-pink-500 shadow-2xl">
        <h2 class="text-2xl text-white font-display mb-2 uppercase tracking-widest drop-shadow-md">How to get past the bouncer:</h2>
        <p class="text-zinc-300 leading-relaxed text-sm">
          Drop a valid email or phone number below to unlock the guest list.
        </p>
      </div>
      
      <div class="bg-zinc-900/60 backdrop-blur-md border border-pink-800 p-5 sm:p-8 shadow-2xl flex flex-col items-center">
        <h1 class="text-4xl md:text-6xl text-white font-display mb-2 uppercase text-center w-full drop-shadow-lg">Box Office (RSVP)</h1>
        
        <div class="text-center mb-8 mt-4">
          <h2 class="text-xl md:text-2xl text-pink-400 font-display uppercase tracking-widest mb-2 drop-shadow-sm">Flash your ID at the Door</h2>
          <p class="text-zinc-300 uppercase tracking-widest text-xs sm:text-sm">Enter your Email or Phone Number to RSVP</p>
        </div>
        
        <form class="flex flex-col gap-4 w-full max-w-md" onsubmit="event.preventDefault();">
          <input 
            type="text" 
            placeholder="EMAIL OR PHONE NUMBER" 
            class="w-full bg-zinc-950/80 border border-pink-800 text-zinc-100 px-4 py-4 text-center tracking-widest focus:outline-none focus:border-pink-500 transition-colors lowercase" 
          />      
          <button type="button" class="w-full bg-pink-600 hover:bg-pink-500 text-white font-bold text-lg uppercase tracking-widest py-4 transition-colors">Find My Ticket</button>
        </form>
      </div>

    </main>
  </div>
</Layout>