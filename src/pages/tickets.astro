---
import Layout from '../components/Layout.astro';
import Nav from '../components/Nav.astro';
import { db } from '../db';
import { guests, settings } from '../db/schema';
import { eq, or } from 'drizzle-orm';

let guestRecord = null;
let lookupError = null;
const isSuccess = Astro.url.searchParams.get('success');

// Date Formatter
const formatDateTime = (dateObj: Date) => {
  return new Date(dateObj).toLocaleString('en-US', {
    timeZone: 'America/New_York',
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    timeZoneName: 'short'
  });
};

// Fetch Date Settings
const siteSettingsQuery = await db.select().from(settings).limit(1);
const siteSettings = siteSettingsQuery[0];
const now = new Date();
let canRsvp = true;
let customMessage = null;

if (siteSettings) {
  if (now < siteSettings.rsvpOpenDate) {
    canRsvp = false;
    customMessage = siteSettings.earlyMessage;
  } else if (now > siteSettings.rsvpCloseDate) {
    canRsvp = false;
    customMessage = siteSettings.lateMessage;
  }
}

if (Astro.request.method === 'POST' && canRsvp) {
  const data = await Astro.request.formData();
  const searchValue = data.get('searchValue')?.toString().trim().toLowerCase() || '';
  
  if (searchValue) {
    const phoneSearch = searchValue.replace(/\D/g, '').replace(/^1/, '');
    const conditions = [];
    
    if (searchValue.includes('@')) {
      conditions.push(eq(guests.email, searchValue));
    }
    if (phoneSearch.length >= 7) {
      conditions.push(eq(guests.phoneNumber, phoneSearch));
    }
    // Fallback search just in case
    if (conditions.length === 0) {
       conditions.push(eq(guests.email, searchValue));
    }

    const found = await db.select().from(guests).where(or(...conditions));
    if (found.length > 0) {
      guestRecord = found[0];
    } else {
      lookupError = "We couldn't find those details on the VIP list. Please reach out to Trent or Shy.";
    }
  }
}
---
<Layout title="Box Office">
  <Nav />
  <main class="max-w-3xl mx-auto p-6 w-full mt-8">
    
    {isSuccess && !guestRecord && (
      <div class="bg-emerald-900/50 border border-emerald-500 text-emerald-200 p-6 mb-8 text-center shadow-xl">
        <h2 class="font-display text-3xl mb-2 uppercase tracking-widest">Ticket Confirmed</h2>
        <p>Your choices have been logged. Need to change something? Enter your email or phone number below to update your RSVP.</p>
      </div>
    )}

    {!canRsvp && (
      <div class="bg-zinc-900 border border-zinc-800 p-8 shadow-2xl text-center">
        <h1 class="text-4xl md:text-6xl text-zinc-100 font-display mb-4 uppercase">Box Office</h1>
        <p class="text-amber-600 text-xl font-bold uppercase tracking-widest">{customMessage}</p>
        {siteSettings && (
          <p class="text-zinc-500 text-xs uppercase tracking-widest mt-8">
            RSVP Window: {formatDateTime(siteSettings.rsvpOpenDate)} - {formatDateTime(siteSettings.rsvpCloseDate)}
          </p>
        )}
      </div>
    )}

    {canRsvp && !guestRecord && (
      <div class="bg-zinc-900 border border-zinc-800 p-5 sm:p-8 shadow-2xl flex flex-col items-center">
        <h1 class="text-4xl md:text-6xl text-zinc-100 font-display mb-2 uppercase text-center w-full">Box Office (RSVP)</h1>
        
        {siteSettings && (
          <div class="text-zinc-500 text-xs uppercase tracking-widest mb-6 border border-zinc-800 bg-zinc-950 px-4 py-2">
            Open until {formatDateTime(siteSettings.rsvpCloseDate)}
          </div>
        )}

        <div class="text-center mb-8">
          <h2 class="text-xl md:text-2xl text-amber-500 font-display uppercase tracking-widest mb-2">Flash your ID at the Door</h2>
          <p class="text-zinc-400 uppercase tracking-widest text-xs sm:text-sm">Enter your Email or Phone Number to RSVP</p>
        </div>
        
        {lookupError && <p class="text-red-500 mb-6 font-bold uppercase tracking-wider bg-red-950/50 border border-red-900 px-4 py-2 w-full text-center">{lookupError}</p>}
        
        <form method="POST" class="flex flex-col gap-4 w-full max-w-md">
          <input 
            type="text" 
            name="searchValue" 
            required 
            placeholder="EMAIL OR PHONE NUMBER" 
            oninput="this.value = this.value.toLowerCase().replace(/ /g, '')"
            class="w-full bg-zinc-950 border border-zinc-700 text-zinc-100 px-4 py-4 text-center tracking-widest focus:outline-none focus:border-amber-600 transition-colors" 
          />      
          <button type="submit" class="w-full bg-amber-700 hover:bg-amber-600 text-zinc-950 font-bold text-lg uppercase tracking-widest py-4 transition-colors">Find My Ticket</button>
        </form>
      </div>
    )}

    {guestRecord && (
      <div class="bg-zinc-900 border border-zinc-800 p-4 sm:p-8 shadow-2xl">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 border-b border-zinc-800 pb-4 mb-8">
          <div class="w-full sm:w-auto overflow-hidden">
            <h1 class="text-3xl sm:text-4xl text-zinc-100 font-display uppercase tracking-widest truncate">Update Ticket</h1>
            <p class="text-amber-600 uppercase tracking-widest text-xs sm:text-sm font-bold mt-1 truncate">Party under: {guestRecord.firstName} {guestRecord.lastName || ''}</p>
          </div>
          <a href="/tickets" class="text-zinc-500 hover:text-zinc-300 text-sm font-bold uppercase tracking-wider whitespace-nowrap">&larr; Back</a>
        </div>

        {Astro.url.searchParams.get('error') === 'duplicate' && (
          <div class="bg-red-950/50 border border-red-900 text-red-500 px-4 py-3 mb-6 text-xs font-bold uppercase tracking-widest text-center">
            That email or phone number is already registered to another guest.
          </div>
        )}

        <form action="/api/rsvp" method="POST" id="rsvp-form" class="flex flex-col gap-8">
          <input type="hidden" name="id" value={guestRecord.id} />

          <div class="border border-zinc-700 bg-zinc-950/50 p-4 sm:p-6">
            <h3 class="text-xl font-display text-zinc-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">
              Contact Info
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Email</label>
                <input type="email" name="email" value={guestRecord.email || ''} class="w-full bg-zinc-900 border border-zinc-700 text-zinc-100 px-4 py-3 focus:outline-none focus:border-amber-600 text-sm" />
              </div>
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Phone Number</label>
                <input type="text" name="phoneNumber" value={guestRecord.phoneNumber || ''} class="w-full bg-zinc-900 border border-zinc-700 text-zinc-100 px-4 py-3 focus:outline-none focus:border-amber-600 text-sm" />
              </div>
            </div>
          </div>

          <div class="border border-zinc-700 bg-zinc-950/50 p-4 sm:p-6">
            <h3 class="text-xl font-display text-amber-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">
              {guestRecord.firstName} {guestRecord.lastName || ''} (Main)
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-1 gap-4">
              <div>
                <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Attending?</label>
                <select name="isAttending" id="main-attending" required class="w-full bg-zinc-900 border-2 border-zinc-700 hover:border-zinc-500 text-zinc-100 px-4 py-4 focus:outline-none focus:border-amber-500 uppercase text-base font-bold tracking-widest cursor-pointer transition-colors">
                  <option value="" disabled selected={!guestRecord.hasRsvpd}>-- Make a Selection --</option>
                  <option value="true" selected={guestRecord.hasRsvpd && guestRecord.isAttending === true}>Hell Yes</option>
                  <option value="false" selected={guestRecord.hasRsvpd && guestRecord.isAttending === false}>Can't Make It</option>
                </select>
              </div>
            </div>
          </div>

          {guestRecord.allocatedPlusOnes >= 1 && (
            <div class="border border-zinc-700 bg-zinc-950/50 p-4 sm:p-6">
              <h3 class="text-xl font-display text-emerald-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">
                {guestRecord.p1Name || 'Plus One'}
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-1 gap-4">
                <div>
                  <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Attending?</label>
                  <select name="p1Attending" id="p1-attending" required class="w-full bg-zinc-900 border-2 border-zinc-700 hover:border-zinc-500 text-zinc-100 px-4 py-4 focus:outline-none focus:border-emerald-500 uppercase text-base font-bold tracking-widest cursor-pointer transition-colors">
                    <option value="" disabled selected={guestRecord.p1Attending === 'pending'}>-- Make a Selection --</option>
                    <option value="true" selected={guestRecord.p1Attending === 'true'}>Hell Yes</option>
                    <option value="false" selected={guestRecord.p1Attending === 'false'}>Can't Make It</option>
                  </select>
                </div>
              </div>
            </div>
          )}

          {guestRecord.allocatedPlusOnes >= 2 && (
            <div class="border border-zinc-700 bg-zinc-950/50 p-4 sm:p-6">
              <h3 class="text-xl font-display text-emerald-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">
                {guestRecord.p2Name || 'Plus Two'}
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-1 gap-4">
                <div>
                  <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Attending?</label>
                  <select name="p2Attending" id="p2-attending" required class="w-full bg-zinc-900 border-2 border-zinc-700 hover:border-zinc-500 text-zinc-100 px-4 py-4 focus:outline-none focus:border-emerald-500 uppercase text-base font-bold tracking-widest cursor-pointer transition-colors">
                    <option value="" disabled selected={guestRecord.p2Attending === 'pending'}>-- Make a Selection --</option>
                    <option value="true" selected={guestRecord.p2Attending === 'true'}>Hell Yes</option>
                    <option value="false" selected={guestRecord.p2Attending === 'false'}>Can't Make It</option>
                  </select>
                </div>
              </div>
            </div>
          )}

          {guestRecord.allocatedPlusOnes >= 3 && (
            <div class="border border-zinc-700 bg-zinc-950/50 p-4 sm:p-6">
              <h3 class="text-xl font-display text-emerald-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">
                {guestRecord.p3Name || 'Plus Three'}
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-1 gap-4">
                <div>
                  <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2">Attending?</label>
                  <select name="p3Attending" id="p3-attending" required class="w-full bg-zinc-900 border-2 border-zinc-700 hover:border-zinc-500 text-zinc-100 px-4 py-4 focus:outline-none focus:border-emerald-500 uppercase text-base font-bold tracking-widest cursor-pointer transition-colors">
                    <option value="" disabled selected={guestRecord.p3Attending === 'pending'}>-- Make a Selection --</option>
                    <option value="true" selected={guestRecord.p3Attending === 'true'}>Hell Yes</option>
                    <option value="false" selected={guestRecord.p3Attending === 'false'}>Can't Make It</option>
                  </select>
                </div>
              </div>
            </div>
          )}

          <div>
            <label class="block text-xs font-bold uppercase tracking-widest text-amber-700 mb-2">Dietary Restrictions / Notes (Applies to Party)</label>
            <input type="text" name="dietaryNotes" placeholder="ALLERGIES?" value={guestRecord.dietaryNotes || ''} class="w-full bg-zinc-950 border border-zinc-700 text-zinc-100 px-4 py-3 focus:outline-none focus:border-amber-600 uppercase text-sm tracking-wider" />
          </div>

          <div>
            <label class="block text-xs font-bold uppercase tracking-widest text-amber-700 mb-2">Song Request</label>
            <input type="text" name="songRequest" placeholder="WHAT SONG WILL GET YOU IN THE PIT?" value={guestRecord.songRequest || ''} class="w-full bg-zinc-950 border border-zinc-700 text-zinc-100 px-4 py-3 focus:outline-none focus:border-amber-600 uppercase text-sm tracking-wider" />
          </div>

          <button type="submit" class="w-full bg-amber-700 hover:bg-amber-600 text-zinc-950 font-bold text-lg uppercase tracking-widest py-4 transition-colors mt-4">
            Lock It In
          </button>
        </form>
      </div>
    )}
  </main>
</Layout>

<script is:inline>
  let isDirty = false;
  const rsvpForm = document.getElementById('rsvp-form');

  if (rsvpForm) {
    rsvpForm.addEventListener('input', () => { isDirty = true; });
    rsvpForm.addEventListener('change', () => { isDirty = true; });
    rsvpForm.addEventListener('submit', () => { isDirty = false; });
  }

  window.addEventListener('beforeunload', (e) => {
    if (isDirty) {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  // Cascading "No" Logic
  const mainAttending = document.getElementById('main-attending');
  if (mainAttending) {
    mainAttending.addEventListener('change', (e) => {
      if (e.target.value === 'false') {
        let partyChanged = false;
        
        ['p1-attending', 'p2-attending', 'p3-attending'].forEach(id => {
          const pSelect = document.getElementById(id);
          // If the plus one isn't already 'false', change them to 'false'
          if (pSelect && pSelect.value !== 'false') {
            pSelect.value = 'false';
            pSelect.dispatchEvent(new Event('change'));
            partyChanged = true;
          }
        });
        
        // Only show the alert if we actually changed someone else's RSVP
        if (partyChanged) {
          alert("Since you can't make it, we've updated your party's RSVP to match. We'll miss you guys!");
        }
      }
    });
  }
</script>